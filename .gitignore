# .gitignore dosyasına .env ve diğer hassas dosyaları ekle
@"
# Environment variables
.env
.env.local
.env.production
.env.development

# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
out/

# Vercel
.vercel

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
"@ | Set-Content .gitignore
